# ==========================================
# SUPABASE CONFIGURATION
# ==========================================
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# ==========================================
# GOOGLE OAUTH CONFIGURATION
# ==========================================
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ==========================================
# BACKEND CONFIGURATION
# ==========================================
REACT_APP_BACKEND_URL=http://localhost:8000

# ==========================================
# BACKEND (server.py) ENV VARS
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
RESEND_API_KEY=your-resend-api-key-here
JWT_SECRET=your-super-secret-key-change-in-production
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
APIFY_API_TOKEN=your-apify-api-token

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
EMAIL_FROM=noreply@hirelytic.com
EMAIL_SENDER_NAME=Hire-Lytics
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_REQUIRE_AUTH=true
EMAIL_DEBUG_OTP=false

# ==========================================
# SECURITY
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000
CORS_ORIGIN_REGEX=^http://(localhost|127\\.0\\.0\\.1)(:\\d+)?$
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# GROQ API (existing)
# ==========================================
GROQ_API_KEY=your-groq-api-key

# ==========================================
# TEMPLATE DATA (backend)
# ==========================================
TEMPLATES_SOURCE_URL=https://raw.githubusercontent.com/harshu07-collab/resume-templates/refs/heads/main/templates.json
TEMPLATES_REFRESH_SECONDS=300
TEMPLATES_API_TOKEN=optional-api-token
TEMPLATES_PROVIDER=auto
JSONRESUME_THEME_LIST_URL=https://docs.jsonresume.org/themes
JSONRESUME_PREVIEW_BASE=https://registry.jsonresume.org
JSONRESUME_PREVIEW_USERNAME=thomasdavis
JSONRESUME_MAX_TEMPLATES=24
JSONRESUME_VALIDATE_TEMPLATES=true
